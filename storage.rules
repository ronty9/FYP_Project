rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. Rule for Pets (Keep existing logic)
    match /pets/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Rule for Profile Images
    match /profile_images/{userId}/{allPaths=**} {
       // This allows logged in users to upload their own profile image
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. Rule for Scan Images
    match /scan_images/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
